digraph ModeloDimensionalKimball {
    graph [rankdir=LR, splines=curved, nodesep=0.9, ranksep=2.2, bgcolor="white", fontname="Helvetica"];
    node [shape=plaintext, fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize=10, color="#546E7A", penwidth=1.2];

    // ---------------------------------------------------------------
    // FACT TABLES - each carries its FULL set of dimension FKs
    // directly (conformed dimension bus, Kimball-style). No link/bridge
    // table: every fact relates straight to every dimension it needs.
    // dim_tempo is a SINGLE physical table, reused three times through
    // role aliasing (Data_Venda / Data_Remessa / Data_Devolucao) - the
    // classic Kimball role-playing dimension, implemented as an SQL
    // VIEW/alias per role in a relational engine, not a physically
    // duplicated table.
    // ---------------------------------------------------------------
    fact_vendas [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#F0D77B">
            <tr><td bgcolor="#B08D00"><font color="white"><b>fact_vendas</b></font></td></tr>
            <tr><td align="left">key_pedido (DD)</td></tr>
            <tr><td align="left">key_peditem (PK)</td></tr>
            <tr><td align="left">key_produto (FK)</td></tr>
            <tr><td align="left">key_cliente (FK)</td></tr>
            <tr><td align="left">key_vendedor (FK)</td></tr>
            <tr><td align="left">key_data (FK, role Data_Venda)</td></tr>
            <tr><td align="left">flg_cancelado</td></tr>
            <tr><td align="left">nm_vendas</td></tr>
            <tr><td align="left">nm_qtde_venda</td></tr>
            <tr><td align="left">nm_valor_venda</td></tr>
            <tr><td align="left">nm_valor_custo</td></tr>
            <tr><td align="left">nm_valor_frete</td></tr>
            <tr><td align="left">nm_valor_margem</td></tr>
            <tr><td align="left">nm_perc_frete</td></tr>
        </table>
    >];

    fact_remessas [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#F0D77B">
            <tr><td bgcolor="#B08D00"><font color="white"><b>fact_remessas</b></font></td></tr>
            <tr><td align="left">key_pedido (PK)</td></tr>
            <tr><td align="left">key_cliente (FK)</td></tr>
            <tr><td align="left">key_vendedor (FK)</td></tr>
            <tr><td align="left">key_data (FK, role Data_Remessa)</td></tr>
            <tr><td align="left">nm_remessas</td></tr>
            <tr><td align="left">nm_qtde_remessas</td></tr>
            <tr><td align="left">nm_valor_remessas</td></tr>
            <tr><td align="left">nm_custo_remessas</td></tr>
            <tr><td align="left">nm_frete_remessas</td></tr>
            <tr><td align="left">nm_margem_remessas</td></tr>
            <tr><td align="left">nm_perc_frete_remessas</td></tr>
            <tr><td align="left">nm_leadtime_remessa</td></tr>
        </table>
    >];

    fact_devolucoes [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#F0D77B">
            <tr><td bgcolor="#B08D00"><font color="white"><b>fact_devolucoes</b></font></td></tr>
            <tr><td align="left">key_devolucao (DD)</td></tr>
            <tr><td align="left">key_devolucao_item (PK)</td></tr>
            <tr><td align="left">key_pedido (DD)</td></tr>
            <tr><td align="left">key_peditem (DD)</td></tr>
            <tr><td align="left">key_produto (FK)</td></tr>
            <tr><td align="left">key_cliente (FK)</td></tr>
            <tr><td align="left">key_vendedor (FK)</td></tr>
            <tr><td align="left">key_data (FK, role Data_Devolucao)</td></tr>
            <tr><td align="left">str_observacao</td></tr>
            <tr><td align="left">nm_devolucoes</td></tr>
            <tr><td align="left">nm_qtde_devolvida</td></tr>
            <tr><td align="left">nm_valor_devolucao</td></tr>
            <tr><td align="left">nm_leadtime_devolucao</td></tr>
        </table>
    >];

    // ---------------------------------------------------------------
    // DIMENSIONS - conformed: shared directly by every fact that needs
    // them (the defining trait of a Kimball "dimension bus").
    // ---------------------------------------------------------------
    dim_cliente [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#BCBEC2">
            <tr><td bgcolor="#6E7075"><font color="white"><b>dim_cliente</b></font></td></tr>
            <tr><td align="left">key_cliente (PK)</td></tr>
            <tr><td align="left">gen_cliente</td></tr>
            <tr><td align="left">str_cliente</td></tr>
            <tr><td align="left">str_cliente_contato</td></tr>
            <tr><td align="left">str_telefone</td></tr>
            <tr><td align="left">str_cidade</td></tr>
            <tr><td align="left">str_pais</td></tr>
        </table>
    >];

    dim_vendedor [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#BCBEC2">
            <tr><td bgcolor="#6E7075"><font color="white"><b>dim_vendedor</b></font></td></tr>
            <tr><td align="left">key_vendedor (PK)</td></tr>
            <tr><td align="left">gen_vendedor</td></tr>
            <tr><td align="left">str_vendedor</td></tr>
            <tr><td align="left">str_vendedor_sexo</td></tr>
            <tr><td align="left">str_cidade_vendedor</td></tr>
            <tr><td align="left">str_pais_vendedor</td></tr>
            <tr><td align="left">str_gerente</td></tr>
        </table>
    >];

    dim_produto [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#BCBEC2">
            <tr><td bgcolor="#6E7075"><font color="white"><b>dim_produto</b></font></td></tr>
            <tr><td align="left">key_produto (PK)</td></tr>
            <tr><td align="left">gen_produto</td></tr>
            <tr><td align="left">str_produto_referencia</td></tr>
            <tr><td align="left">str_produto</td></tr>
            <tr><td align="left">str_categoria</td></tr>
            <tr><td align="left">str_departamento</td></tr>
        </table>
    >];

    dim_tempo [label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="6" bgcolor="#BCBEC2">
            <tr><td bgcolor="#6E7075"><font color="white"><b>dim_tempo</b></font></td></tr>
            <tr><td align="left">key_data (PK)</td></tr>
            <tr><td align="left">gen_data</td></tr>
            <tr><td align="left">nm_ano</td></tr>
            <tr><td align="left">nm_trimestre</td></tr>
            <tr><td align="left">nm_mes</td></tr>
            <tr><td align="left">str_nome_mes</td></tr>
            <tr><td align="left">str_dia_semana</td></tr>
        </table>
    >];

    { rank=same; dim_cliente; dim_vendedor; dim_produto; dim_tempo; }
    { rank=same; fact_vendas; fact_remessas; fact_devolucoes; }

    // ---------------------------------------------------------------
    // RELATIONSHIPS - direct dim -> fact, fanning out to every fact
    // that uses each dimension (conformed dimension bus matrix).
    // ---------------------------------------------------------------
    dim_cliente  -> fact_vendas     [label="1:N", color="#8E5B3F"];
    dim_cliente  -> fact_remessas   [label="1:N", color="#8E5B3F"];
    dim_cliente  -> fact_devolucoes [label="1:N", color="#8E5B3F"];

    dim_vendedor -> fact_vendas     [label="1:N", color="#3F6E8E"];
    dim_vendedor -> fact_remessas   [label="1:N", color="#3F6E8E"];
    dim_vendedor -> fact_devolucoes [label="1:N", color="#3F6E8E"];

    dim_produto  -> fact_vendas     [label="1:N", color="#6E3F8E"];
    dim_produto  -> fact_devolucoes [label="1:N", color="#6E3F8E"];

    dim_tempo    -> fact_vendas     [label="1:N (Data_Venda)", color="#8E8E3F"];
    dim_tempo    -> fact_remessas   [label="1:N (Data_Remessa)", color="#8E8E3F"];
    dim_tempo    -> fact_devolucoes [label="1:N (Data_Devolucao)", color="#8E8E3F"];

    // ---------------------------------------------------------------
    // NOTE: this is the textbook Kimball star (dimension bus matrix) -
    // dimensions shared directly by every fact that needs them, and a
    // single date dimension reused through role aliasing. It maps
    // cleanly to a relational engine (SQL joins, one alias per role),
    // but is NOT directly usable in Qlik's associative engine as drawn:
    // fact_vendas, fact_remessas and fact_devolucoes here share 2+
    // field names with each other (key_cliente, key_vendedor, key_data),
    // which Qlik resolves by creating synthetic key tables. That is
    // exactly why this project's Gold layer implements the link-table
    // variant instead (see modelo_dimensional_qlik.png) - same
    // conformed-dimension intent, adapted to how Qlik actually
    // associates tables.
    // ---------------------------------------------------------------

    label = "VendasODS - Modelo Dimensional Kimball (tradicional) - Referencia conceitual";
    labelloc = "t";
    fontsize = 20;
}
